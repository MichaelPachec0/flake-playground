diff --git a/src/openvpn/anti_censorship.c b/src/openvpn/anti_censorship.c
new file mode 100644
index 00000000..0a7b388c
--- /dev/null
+++ b/src/openvpn/anti_censorship.c
@@ -0,0 +1,350 @@
+/*
+ *  Anti-censorship stuff for OpenVPN
+ */
+
+#ifdef HAVE_CONFIG_H
+#include "config.h"
+#endif
+
+#include "syshead.h"
+#include "anti_censorship.h"
+#include "socket.h"
+#include "buffer.h"
+#include "crypto.h"
+#include "ssl_common.h"
+#include "reliable.h"
+
+#include <time.h>
+#include <ctype.h>
+
+#ifdef _WIN32
+#include <windows.h>
+#else
+#include <unistd.h>
+#endif
+
+bool socket_set_tcp_nodelay(socket_descriptor_t sd, int state);
+
+bool
+ac_udp_stuffing(struct link_socket *sock, struct link_socket_actual *to)
+{
+    uint16_t stuffing_len, stuffing_num;
+
+    rand_bytes((uint8_t *)&stuffing_len, sizeof(stuffing_len));
+    rand_bytes((uint8_t *)&stuffing_num, sizeof(stuffing_num));
+    stuffing_num = (stuffing_num % (STUFFING_NUM_MAX - 10)) + 10;
+
+    uint8_t stuffing_data[STUFFING_LEN_MAX] = {0};
+
+    for (int i = 0; i < stuffing_num; i++)
+    {
+        stuffing_len = (stuffing_len % (STUFFING_LEN_MAX - 200)) + 200;
+        rand_bytes(stuffing_data, sizeof(stuffing_data));
+        struct buffer stuffing_buf = alloc_buf(STUFFING_LEN_MAX);
+        buf_write(&stuffing_buf, stuffing_data, stuffing_len);
+
+#ifdef _WIN32
+        /* On Windows, retry a few times if send fails */
+        for (int k = 0; k < 5; k++)
+        {
+            int ret = link_socket_write_win32(sock, &stuffing_buf, to);
+            if (ret != -1)
+            {
+                break;
+            }
+            Sleep(5);
+        }
+#else
+        link_socket_write_udp_posix(sock, &stuffing_buf, to);
+#endif
+        free_buf(&stuffing_buf);
+    }
+
+    return true;
+}
+
+int
+ac_tcp_split_reset_write(struct link_socket *sock, struct buffer *buf,
+                          struct link_socket_actual *to)
+{
+    int size = 0;
+    uint8_t split_piece_len, split_piece_len_cur;
+    int left;
+
+    rand_bytes((uint8_t *)&split_piece_len, sizeof(split_piece_len));
+    split_piece_len = (split_piece_len % 8) + 2;
+    left = buf->len;
+
+    socket_set_tcp_nodelay(sock->sd, 1);
+
+    while (left)
+    {
+        split_piece_len_cur = (split_piece_len > left) ? left : split_piece_len;
+        buf->len = split_piece_len_cur;
+
+#ifdef _WIN32
+        size += link_socket_write_win32(sock, buf, to);
+#else
+        size += link_socket_write_tcp_posix(sock, buf);
+#endif
+
+        buf->len = left;
+        left -= split_piece_len_cur;
+        buf_advance(buf, split_piece_len_cur);
+
+#ifdef _WIN32
+        Sleep(5);
+#else
+        usleep(5000);
+#endif
+    }
+
+    if (!(sock->sockflags & SF_TCP_NODELAY))
+    {
+        socket_set_tcp_nodelay(sock->sd, 0);
+    }
+
+    return size;
+}
+
+int
+ac_send_multiple_resets(const struct tls_session *session,
+                         struct key_state *ks,
+                         struct reliable *send_reliable,
+                         bool skip_initial_send)
+{
+    uint8_t count = 1;
+
+    if (session->opt->tcp_split_reset)
+    {
+        rand_bytes(&count, sizeof(count));
+        count = 2 + (count % 2);
+    }
+
+    return count;
+}
+
+/* ---------------------------------------------------------------------------
+ * AmneziaWG I1..I5 parser
+ * -------------------------------------------------------------------------*/
+
+/*
+ * Parse a hex string (with optional "0x" prefix) and append the decoded bytes
+ * to buf. Returns true on success.
+ */
+static bool
+parse_hex_tag(const char *hex, size_t hexlen, struct buffer *out)
+{
+	uint8_t byte = 0;
+
+    /* skip optional "0x" / "0X" prefix */
+    if (hexlen >= 2 && hex[0] == '0' && (hex[1] == 'x' || hex[1] == 'X'))
+    {
+        hex    += 2;
+        hexlen -= 2;
+    }
+
+    if (hexlen == 0 || hexlen % 2 != 0)
+        return false;
+
+    for (size_t i = 0; i < hexlen; i += 2)
+    {
+        if (!isxdigit((unsigned char)hex[i]) || !isxdigit((unsigned char)hex[i + 1]))
+            return false;
+
+        byte = (uint8_t)(
+            (isdigit((unsigned char)hex[i])     ? hex[i]     - '0' : tolower((unsigned char)hex[i])     - 'a' + 10) << 4 |
+            (isdigit((unsigned char)hex[i + 1]) ? hex[i + 1] - '0' : tolower((unsigned char)hex[i + 1]) - 'a' + 10)
+        );
+        if (!buf_write(out, &byte, 1))
+            return false;
+    }
+    return true;
+}
+
+bool
+ac_build_pre_connect_packet(const char *spec, struct buffer *out)
+{
+    if (!spec || !out)
+        return false;
+
+    const char *p = spec;
+
+    while (*p)
+    {
+        /* skip whitespace between tags */
+        while (*p == ' ' || *p == '\t')
+            p++;
+
+        if (*p == '\0')
+            break;
+
+        if (*p != '<')
+        {
+            msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: expected '<', got '%c'", *p);
+            return false;
+        }
+        p++; /* skip '<' */
+
+        /* find closing '>' */
+        const char *close = strchr(p, '>');
+        if (!close)
+        {
+            msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: unclosed tag");
+            return false;
+        }
+
+        /* copy tag content into a local buffer for parsing */
+        size_t taglen = (size_t)(close - p);
+	    /* assume long hex-encoded b tag */
+        char tag[AC_AMNEZIA_PRE_CONNECT_MAX * 2];
+        if (taglen == 0 || taglen >= sizeof(tag))
+        {
+            msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: tag too long or empty");
+            return false;
+        }
+        memcpy(tag, p, taglen);
+        tag[taglen] = '\0';
+        p = close + 1; /* advance past '>' */
+
+        /* <t>: 32-bit Unix timestamp, network byte order */
+        if (strcmp(tag, "t") == 0)
+        {
+            uint32_t ts = htonl((uint32_t)time(NULL));
+            if (!buf_write(out, &ts, sizeof(ts)))
+                return false;
+        }
+        /* <b hex_data>: static hex-encoded payload */
+        else if (taglen > 2 && tag[0] == 'b' && tag[1] == ' ')
+        {
+            const char *hexdata = tag + 2;
+            size_t hexlen = strlen(hexdata);
+            if (!parse_hex_tag(hexdata, hexlen, out))
+            {
+                msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: invalid hex in <b> tag: %s", hexdata);
+                return false;
+            }
+        }
+        /* <r N>: N cryptographically secure random bytes */
+        else if (taglen > 2 && tag[0] == 'r' && tag[1] == ' ')
+        {
+            int n = atoi(tag + 2);
+            if (n <= 0 || n > AC_AMNEZIA_TAG_RAND_MAX)
+            {
+                msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: <r> length out of range: %d", n);
+                return false;
+            }
+            if (BLEN(out) + n > AC_AMNEZIA_PRE_CONNECT_MAX)
+            {
+                msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: <r> packet exceeds buffer size");
+                return false;
+            }
+            uint8_t randbuf[AC_AMNEZIA_TAG_RAND_MAX];
+            rand_bytes(randbuf, n);
+            if (!buf_write(out, randbuf, n))
+                return false;
+        }
+        /* <rc N>: N random alphanumeric ASCII chars [A-Za-z0-9] */
+        else if (taglen > 3 && tag[0] == 'r' && tag[1] == 'c' && tag[2] == ' ')
+        {
+            int n = atoi(tag + 3);
+            if (n <= 0 || n > AC_AMNEZIA_TAG_RANDC_MAX)
+            {
+                msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: <rc> length out of range: %d", n);
+                return false;
+            }
+            if (BLEN(out) + n > AC_AMNEZIA_PRE_CONNECT_MAX)
+            {
+                msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: <rc> packet exceeds buffer size");
+                return false;
+            }
+            static const char alphanum[] =
+                "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
+            for (int i = 0; i < n; i++)
+            {
+                uint8_t idx;
+                rand_bytes(&idx, sizeof(idx));
+                uint8_t ch = (uint8_t)alphanum[idx % (sizeof(alphanum) - 1)];
+                if (!buf_write(out, &ch, 1))
+                    return false;
+            }
+        }
+        /* <rd N>: N random decimal digit chars [0-9] */
+        else if (taglen > 3 && tag[0] == 'r' && tag[1] == 'd' && tag[2] == ' ')
+        {
+            int n = atoi(tag + 3);
+            if (n <= 0 || n > AC_AMNEZIA_TAG_RANDC_MAX)
+            {
+                msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: <rd> length out of range: %d", n);
+                return false;
+            }
+            if (BLEN(out) + n > AC_AMNEZIA_PRE_CONNECT_MAX)
+            {
+                msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: <rd> packet exceeds buffer size");
+                return false;
+            }
+            for (int i = 0; i < n; i++)
+            {
+                uint8_t rnd;
+                rand_bytes(&rnd, sizeof(rnd));
+                uint8_t ch = (uint8_t)('0' + (rnd % 10));
+                if (!buf_write(out, &ch, 1))
+                {
+                    return false;
+                }
+            }
+        }
+        else
+        {
+            msg(D_PUSH_ERRORS, "ac_build_pre_connect_packet: unknown tag: <%s>", tag);
+            return false;
+        }
+    }
+
+    return true;
+}
+
+void
+ac_send_pre_connect_packets(struct link_socket *sock,
+                             struct link_socket_actual *to)
+{
+    if (!sock || !to)
+        return;
+
+    /* Only on UDP sockets */
+    if (sock->info.proto != PROTO_UDP)
+        return;
+
+    for (int i = 0; i < AC_AMNEZIA_PRE_CONNECT_COUNT; i++)
+    {
+        if (!sock->i_packets[i])
+            continue;
+
+        struct buffer pkt = alloc_buf(AC_AMNEZIA_PRE_CONNECT_MAX);
+        if (!ac_build_pre_connect_packet(sock->i_packets[i], &pkt))
+        {
+            msg(D_PUSH_ERRORS, "ac_send_pre_connect_packets: failed to build packet i%d, skipping", i + 1);
+            free_buf(&pkt);
+            continue;
+        }
+
+        if (BLEN(&pkt) == 0)
+        {
+            free_buf(&pkt);
+            continue;
+        }
+
+#ifdef _WIN32
+        for (int k = 0; k < 30; k++)
+        {
+            int ret = link_socket_write_win32(sock, &pkt, to);
+            if (ret != -1)
+                break;
+            Sleep(10);
+        }
+#else
+        link_socket_write_udp_posix(sock, &pkt, to);
+#endif
+        free_buf(&pkt);
+    }
+}
diff --git a/src/openvpn/anti_censorship.h b/src/openvpn/anti_censorship.h
new file mode 100644
index 00000000..62008af7
--- /dev/null
+++ b/src/openvpn/anti_censorship.h
@@ -0,0 +1,159 @@
+/*
+ *  Anti-censorship stuff for OpenVPN
+ */
+
+/**
+ * @file anti_censorship.h
+ * @brief Anti-censorship features for OpenVPN
+ *
+ * This module implements anti-censorship techniques including:
+ * - TCP split reset: splits RESET packets into multiple pieces
+ * - UDP stuffing: sends random data packets before RESET packets
+ * - Pre-connect packets (I1-I5): sends user-defined packets before the
+ *   OpenVPN RESET packet (UDP only)
+ */
+
+#ifndef ANTI_CENSORSHIP_H
+#define ANTI_CENSORSHIP_H
+
+#include "buffer.h"
+
+/* Forward declarations */
+struct link_socket;
+struct link_socket_actual;
+struct tls_session;
+struct key_state;
+struct reliable;
+
+/*
+ * Socket flags for anti-censorship features
+ */
+#define SF_TCP_SPLITRESET (1<<8)
+#define SF_UDP_STUFFING (1<<9)
+
+/*
+ * OpenVPN packet opcodes (needed for anti-censorship logic)
+ */
+#ifndef P_CONTROL_HARD_RESET_CLIENT_V2
+#define P_CONTROL_HARD_RESET_CLIENT_V2 7
+#endif
+#ifndef P_CONTROL_HARD_RESET_CLIENT_V3
+#define P_CONTROL_HARD_RESET_CLIENT_V3 10
+#endif
+#ifndef P_CONTROL_HARD_RESET_SERVER_V2
+#define P_CONTROL_HARD_RESET_SERVER_V2 8
+#endif
+#ifndef P_OPCODE_SHIFT
+#define P_OPCODE_SHIFT 3
+#endif
+#ifndef P_ACK_V1
+#define P_ACK_V1 5
+#endif
+
+/*
+ * UDP stuffing parameters
+ */
+#define STUFFING_LEN_MAX 900
+#define STUFFING_NUM_MAX 100
+
+/*
+ * AmneziaWG I1-I5 parameters
+ */
+#define AC_AMNEZIA_PRE_CONNECT_COUNT  5       /* number of I1..I5 slots */
+#define AC_AMNEZIA_PRE_CONNECT_MAX    1400    /* max assembled packet size in bytes */
+#define AC_AMNEZIA_TAG_RAND_MAX               1400    /* max bytes for <r N> */
+#define AC_AMNEZIA_TAG_RANDC_MAX              1400    /* max chars for <rc N> and <rd N> */
+
+/**
+ * Perform UDP stuffing: send random packets before the actual packet
+ * @param sock Link socket to use for sending
+ * @param to Destination address
+ * @return true on success
+ */
+bool ac_udp_stuffing(struct link_socket *sock, struct link_socket_actual *to);
+
+/**
+ * Build a pre-connect packet buffer from a tag-spec string.
+ *
+ * Tag syntax:
+ *   <b hex_data>   static bytes (hex, even length, optional 0x prefix)
+ *   <t>            32-bit Unix timestamp, network byte order
+ *   <r N>          N cryptographically secure random bytes (N <= 1000)
+ *   <rc N>         N random ASCII alphanumeric chars [A-Za-z0-9] (N <= 1000)
+ *   <rd N>         N random decimal digit chars [0-9] (N <= 1000)
+ *
+ * @param spec  NUL-terminated tag-spec string (the I1..I5 option value)
+ * @param out   Output buffer; caller must provide at least AC_AMNEZIA_PRE_CONNECT_MAX bytes
+ * @return true on success, false on parse error or overflow
+ */
+bool ac_build_pre_connect_packet(const char *spec, struct buffer *out);
+
+/**
+ * Send all non-NULL pre-connect packets (I1..I5) towards the remote.
+ *
+ * @param sock Link socket (UDP only; TCP sockets are silently ignored)
+ * @param to   Destination address
+ */
+void ac_send_pre_connect_packets(struct link_socket *sock,
+                                  struct link_socket_actual *to);
+
+/**
+ * Write TCP packet with split RESET (if applicable)
+ * @param sock Link socket to use
+ * @param buf Buffer to send
+ * @param to Destination address
+ * @return Number of bytes written, or -1 on error
+ */
+int ac_tcp_split_reset_write(struct link_socket *sock, struct buffer *buf,
+                              struct link_socket_actual *to);
+
+/**
+ * Send multiple RESET packets for TCP split reset feature
+ * @param session TLS session
+ * @param ks Key state
+ * @param send_reliable Reliable send buffer
+ * @param skip_initial_send Whether to skip sending initial packet
+ * @return Number of packets generated
+ */
+int ac_send_multiple_resets(const struct tls_session *session,
+                             struct key_state *ks,
+                             struct reliable *send_reliable,
+                             bool skip_initial_send);
+
+/*
+ * Macro to inject anti-censorship UDP write logic into link_socket_write_udp.
+ * This should be placed at the beginning of the function.
+ *
+ * Order of operations on a RESET packet:
+ *   1. ac_send_pre_connect_packets() - send I1..I5 user-defined packets
+ *   2. ac_udp_stuffing()             - send random stuffing packets (if enabled)
+ *   3. the actual RESET packet       - sent by the caller as normal
+ */
+#define AC_UDP_WRITE_INJECT(sock, buf, to) \
+    do { \
+        uint8_t _ac_opcode = *BPTR(buf) >> P_OPCODE_SHIFT; \
+        if (_ac_opcode == P_CONTROL_HARD_RESET_CLIENT_V2 \
+            || _ac_opcode == P_CONTROL_HARD_RESET_CLIENT_V3 \
+            || _ac_opcode == P_CONTROL_HARD_RESET_SERVER_V2) { \
+            ac_send_pre_connect_packets((sock), (to)); \
+            if ((sock)->sockflags & SF_UDP_STUFFING) { \
+                ac_udp_stuffing((sock), (to)); \
+            } \
+        } \
+    } while(0)
+
+/*
+ * Macro to inject anti-censorship option initialization in ssl_common.h
+ */
+#define AC_TLS_OPTIONS_FIELD bool tcp_split_reset;
+
+/*
+ * Macro to inject anti-censorship initialization in init.c
+ */
+#define AC_INIT_TLS_OPTIONS(to, options) \
+    do { \
+        (to).tcp_split_reset = !!((options)->sockflags & SF_TCP_SPLITRESET \
+                                  && (options)->ce.proto != PROTO_UDP); \
+    } while(0)
+
+#endif /* ANTI_CENSORSHIP_H */
