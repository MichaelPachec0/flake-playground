@@ -49,6 +49,7 @@
 #include "tls_crypt.h"
 #include "forward.h"
 #include "auth_token.h"
+#include "anti_censorship.h"
 #include "mss.h"
 #include "mudp.h"
 #include "dco.h"
@@ -3456,6 +3457,10 @@ do_init_crypto_tls(struct context *c, const unsigned int flags)
     /* let the TLS engine know if keys have to be installed in DCO or not */
     to.dco_enabled = dco_enabled(options);
 
+    /* Anti-censorship: initialize tcp_split_reset option */
+    to.tcp_split_reset = !!(options->sockflags & SF_TCP_SPLITRESET
+                            && options->ce.proto != PROTO_UDP);
+
     /*
      * Initialize OpenVPN's master TLS-mode object.
      */
diff --git a/src/openvpn/options.c b/src/openvpn/options.c
index b3a126da..1eb59d26 100644
--- a/src/openvpn/options.c
+++ b/src/openvpn/options.c
@@ -3060,6 +3060,13 @@ options_postprocess_mutate_ce(struct options *o, struct connection_entry *ce)
         msg(M_WARN, "NOTICE: --explicit-exit-notify ignored for --proto tcp");
         ce->explicit_exit_notification = 0;
     }
+
+    /* I1-I5 for TCP could not be used */
+    for (int i = 0; i < AC_AMNEZIA_PRE_CONNECT_COUNT; i++)
+    {
+        if (o->i_packets[i] && ce->proto != PROTO_UDP)
+            msg(M_WARN, "NOTICE: --I1-I5 are suitable only for proto UDP");
+    }
 }
 
 static void
@@ -7704,6 +7711,27 @@ add_option(struct options *options, char *p[], bool is_inline, const char *file,
         VERIFY_PERMISSION(OPT_P_GENERAL);
         options->server_flags |= SF_TCP_NODELAY_HELPER;
     }
+    else if (streq(p[0], "udp-stuffing") && !p[1])
+    {
+        VERIFY_PERMISSION(OPT_P_GENERAL);
+        if (options->ce.proto == PROTO_UDP) {
+            options->sockflags |= SF_UDP_STUFFING;
+        }
+    }
+    else if (streq(p[0], "tcp-split-reset"))
+    {
+        VERIFY_PERMISSION(OPT_P_GENERAL);
+        options->sockflags |= SF_TCP_SPLITRESET;
+    }
+    else if ((streq(p[0], "i1") || streq(p[0], "i2") || streq(p[0], "i3")
+              || streq(p[0], "i4") || streq(p[0], "i5")
+              || streq(p[0], "I1") || streq(p[0], "I2") || streq(p[0], "I3")
+              || streq(p[0], "I4") || streq(p[0], "I5")) && p[1] && !p[2])
+    {
+        VERIFY_PERMISSION(OPT_P_GENERAL);
+        int idx = p[0][1] - '1'; /* '1'..'5' -> 0..4 */
+        options->i_packets[idx] = p[1];
+    }
     else if (streq(p[0], "stale-routes-check") && p[1] && !p[3])
     {
         int ageing_time, check_interval;
@@ -9311,6 +9339,7 @@ add_option(struct options *options, char *p[], bool is_inline, const char *file,
                 p[0], PACKAGE_VERSION);
         }
     }
+
 err:
     gc_free(&gc);
 }
diff --git a/src/openvpn/options.h b/src/openvpn/options.h
